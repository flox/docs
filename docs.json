{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Flox",
  "appearance": {
    "default": "light"
  },
  "seo": {
    "metatags": {
      "canonical": "https://flox.dev/docs"
    }
  },
  "colors": {
    "primary": "#8D45FF",
    "light": "#B080FF",
    "dark": "#6F2BFF"
  },
  "fonts": {
